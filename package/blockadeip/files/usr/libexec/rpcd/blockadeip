#!/bin/sh

TMP="/tmp/blockadeip-rpc.$$"
read_input() { cat > "$TMP"; }
jget() { jsonfilter -i "$TMP" -e "@.$1" 2>/dev/null; }
reply() { printf '{"ok":%s,"message":"%s"}\n' "$1" "$(printf '%s' "$2" | sed 's/\\/\\\\/g; s/"/\\"/g')"; }

[ "$1" = "call" ] && shift

case "$1" in
        list)
                cat <<'JSON'
{
  "status": {},
  "banlist": {},
  "logs": { "limit": "String" },
  "config": {},
  "add": { "ip": "String" },
  "delete": { "ip": "String" },
  "flush": {},
  "reload": {},
  "public": {},
  "set_enabled": { "enabled": "String" },
  "set_autostart": { "enabled": "String" },
  "save_config": { "threshold": "String", "window": "String", "web_patterns": "String", "ssh_patterns": "String", "extra_patterns": "String", "bark_enabled": "String", "bark_server": "String", "bark_template": "String", "bark_custom_template": "String" },
  "simulate": { "ip": "String" },
  "clear_logs": {},
  "bark_test": {},
  "login_button": { "action": "String" }
}
JSON
                ;;
        status) /usr/sbin/blockadeip status-json ;;
        banlist) /usr/sbin/blockadeip banlist-json ;;
        logs)
                read_input; limit="$(jget limit)"; rm -f "$TMP"; [ -n "$limit" ] || limit=100
                /usr/sbin/blockadeip logs-json "$limit"
                ;;
        config) /usr/sbin/blockadeip config-json ;;
        add)
                read_input; ip="$(jget ip)"; rm -f "$TMP"
                out="$(/usr/sbin/blockadeip add "$ip" 0 manual_luci 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        delete)
                read_input; ip="$(jget ip)"; rm -f "$TMP"
                out="$(/usr/sbin/blockadeip del "$ip" 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        flush)
                out="$(/usr/sbin/blockadeip flush 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        reload)
                out="$(/usr/sbin/blockadeip reload 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        public)
                /usr/sbin/blockadeip public >/dev/null 2>&1
                reply true "public refreshed"
                ;;
        set_enabled)
                read_input; v="$(jget enabled)"; rm -f "$TMP"
                out="$(/usr/sbin/blockadeip set-enabled "$v" 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        set_autostart)
                read_input; v="$(jget enabled)"; rm -f "$TMP"
                out="$(/usr/sbin/blockadeip set-autostart "$v" 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        save_config)
                read_input
                th="$(jget threshold)"; win="$(jget window)"; web="$(jget web_patterns)"; ssh="$(jget ssh_patterns)"; extra="$(jget extra_patterns)"
                be="$(jget bark_enabled)"; bs="$(jget bark_server)"; bt="$(jget bark_template)"; bc="$(jget bark_custom_template)"
                rm -f "$TMP"
                out="$(/usr/sbin/blockadeip save-config "$th" "$win" "$web" "$ssh" "$extra" "$be" "$bs" "$bt" "$bc" 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        simulate)
                read_input; ip="$(jget ip)"; rm -f "$TMP"
                out="$(/usr/sbin/blockadeip simulate "$ip" 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        clear_logs)
                out="$(/usr/sbin/blockadeip clear-logs 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        bark_test)
                out="$(/usr/sbin/blockadeip bark-test 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        login_button)
                read_input; action="$(jget action)"; rm -f "$TMP"
                [ -n "$action" ] || action=install
                out="$(/usr/sbin/blockadeip login-button "$action" 2>&1)"; rc=$?
                [ $rc -eq 0 ] && reply true "$out" || reply false "$out"
                ;;
        *) reply false "unknown method" ;;
esac
