config blockadeip 'main'
        option enabled '1'
        option backend 'auto'
        option set_name 'blockadeip'
        option chain_name 'BLOCKADEIP'
        option threshold '20'
        option window '300'
        option ban_time '0'
        option public_page '1'
        option public_limit '100'
        option public_path '/www/blockadeip'
        option log_path '/etc/blockadeip/blockadeip.log'
        option records_path '/etc/blockadeip/records.tsv'
        option show_full_ip '1'
        option version '1.3.0'
        option repo_url 'https://github.com/sogbtt/openwrt-blockadeip-ipk'
        option changelog 'V1.3: persistent records, configurable match patterns, scroll tables, service toggles, LAN protection, simulation test, ban time column, Bark push config.'
        option web_patterns 'luci: failed login|Login failed|uwsgi-luci.*failed login|nginx.*login failed|openresty.*login failed'
        option ssh_patterns 'bad password|Failed password|invalid user|Exit before auth|authentication failure|dropbear|sshd'
        option extra_patterns ''

config whitelist 'default'
        list ip '127.0.0.1'
        list ip '192.168.0.0/16'
        list ip '10.0.0.0/8'
        list ip '172.16.0.0/12'

config bark 'main'
        option enabled '0'
        option server ''
        option template 'simple'
        option custom_template 'BlockadeIP: {ip} was blocked, reason={reason}, count={count}, time={time}'
